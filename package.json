{
  "name": "crucible",
  "version": "1.0.0",
  "description": "Execution-based AI agent evaluation harness",
  "type": "module",
  "main": "dist/server/api.js",
  "bin": {
    "crucible": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "start": "node dist/server/api.js",
    "serve": "node dist/server/api.js",
    "cli": "node dist/cli/main.js",
    "pretest": "rm -rf dist && tsc",
    "test": "node --test dist/tests/*.test.js",
    "lint": "tsc --noEmit",
    "harness": "node dist/cli/main.js harness",
    "qa": "node dist/cli/main.js qa"
  },
  "keywords": [
    "ai",
    "evaluation",
    "agent",
    "benchmark",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
