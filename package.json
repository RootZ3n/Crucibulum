{
  "name": "crucible",
  "version": "0.1.0",
  "description": "Auditable scoreboard, receipt, and evidence viewer for model and agent trial outputs",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server/api.js",
  "bin": {
    "crucible": "dist/cli/main.js"
  },
  "files": [
    "tsconfig.json",
    "adapters/",
    "cli/",
    "core/",
    "leaderboard/",
    "security/",
    "server/",
    "types/",
    "utils/",
    "tests/",
    "dist/",
    "!dist/tests/",
    "tasks/",
    "oracles/",
    "schemas/",
    "suites/",
    "scripts/",
    "ui/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE",
    ".env.example",
    "crucible.service"
  ],
  "scripts": {
    "build": "tsc",
    "build:clean": "node scripts/build-clean.mjs",
    "dev": "tsc --watch",
    "start": "node dist/server/api.js",
    "serve": "node dist/server/api.js",
    "cli": "node dist/cli/main.js",
    "pretest": "node scripts/build-clean.mjs",
    "test": "node scripts/test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "smoke": "node scripts/smoke.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "audit:release": "npm audit --audit-level=moderate",
    "oracle:hash": "node dist/cli/main.js oracle-hash",
    "harness": "node dist/cli/main.js harness",
    "qa": "node dist/cli/main.js qa"
  },
  "keywords": [
    "ai",
    "evaluation",
    "agent",
    "benchmark",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
