        "path": "src/search/engine.js",
        "lines_added": 15,
        "lines_removed": 8,
        "patch": "diff --git a/src/search/engine.js b/src/search/engine.js\nindex 463f139..4046d12 100644\n--- a/src/search/engine.js\n+++ b/src/search/engine.js\n@@ -13,16 +13,23 @@ function search(query, documents) {\n \n   for (const doc of documents) {\n     let score = 0;\n-    const content = doc.content || '';\n-\n-    for (const term of terms) {\n-      // BUG: re-splitting the document content for EVERY term creates O(terms * words) work\n-      // per document, making the total complexity O(docs * terms * words)\n-      const words = content.toLowerCase().split(/\\s+/);\n-      for (const word of words) {\n-        if (word === term) score++;\n+    const content = (doc.content || '').toLowerCase();\n+    \n+    // Split content once per document — O(words)\n+    const words = content.split(/\\s+/);\n+    \n+    // Count word occurrences in a single pass — O(words)\n+    const wordCounts = {};\n+    for (const word of words) {\n+      if (word) {\n+        wordCounts[word] = (wordCounts[word] || 0) + 1;\n       }\n     }\n+    \n+    // Sum scores for each term — O(terms)\n+    for (const term of terms) {\n+      score += wordCounts[term] || 0;\n+    }\n \n     if (score > 0) {\n       results.push({ id: doc.id, title: doc.title || '', score });\n@@ -38,3 +45,4 @@ function searchWithLimit(query, documents, limit) {\n }\n \n module.exports = { search, searchWithLimit };\n+"
      }
