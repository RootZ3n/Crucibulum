  "diff": {
    "files_changed": [
      {
        "path": "src/api/errors.js",
        "lines_added": 26,
        "lines_removed": 5,
        "patch": "diff --git a/src/api/errors.js b/src/api/errors.js\nindex 04f065b..6ecdddc 100644\n--- a/src/api/errors.js\n+++ b/src/api/errors.js\n@@ -13,14 +13,35 @@\n  *   - Error code (if available)\n  */\n \n+/**\n+ * Sanitize an error message by removing internal file system paths,\n+ * line numbers, and other internal details.\n+ */\n+function sanitizeMessage(message) {\n+  if (typeof message !== 'string') return 'An error occurred';\n+\n+  let sanitized = message;\n+\n+  // Remove Windows-style absolute paths (e.g., C:\\Users\\app\\src\\file.js)\n+  sanitized = sanitized.replace(/[A-Za-z]:[\\/\\\\](?:[\\w.-]+[\\/\\\\])*[\\w.-]+/g, '[PATH]');\n+\n+  // Remove Unix-style absolute paths and relative paths\n+  // (e.g., /home/user/app/file.js or src/api/handler.js)\n+  sanitized = sanitized.replace(/\\/?[\\w.-]+(?:[\\/\\\\][\\w.-]+)+/g, '[PATH]');\n+\n+  // Remove remaining line/column number references (e.g., :123 or :123:45)\n+  sanitized = sanitized.replace(/:\\d+(:\\d+)*/g, '');\n+\n+  // Remove \"line NNN\" references\n+  sanitized = sanitized.replace(/\\bline\\s+\\d+/gi, '[LINE]');\n+\n+  return sanitized;\n+}\n+\n function formatError(err, statusCode) {\n   return {\n     status: statusCode,\n-    // BUG: err.message often contains internal paths like\n-    // \"ENOENT: no such file or directory, open '/home/app/data/users.json'\"\n-    error: err.message,\n-    // BUG: exposes internal stack trace line\n-    path: err.stack ? err.stack.split('\\n')[1].trim() : null,\n+    error: sanitizeMessage(err.message),\n     code: err.code || null\n   };\n }"
      }
    ],
