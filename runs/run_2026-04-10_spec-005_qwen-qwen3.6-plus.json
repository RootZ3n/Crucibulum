        "path": "src/api/errors.js",
        "lines_added": 8,
        "lines_removed": 5,
        "patch": "diff --git a/src/api/errors.js b/src/api/errors.js\nindex 04f065b..68b69a8 100644\n--- a/src/api/errors.js\n+++ b/src/api/errors.js\n@@ -14,13 +14,16 @@\n  */\n \n function formatError(err, statusCode) {\n+  // Sanitize error message to remove internal file paths\n+  let sanitizedMessage = err.message;\n+  // Remove Unix-style paths (e.g., /home/app/data/users.json)\n+  sanitizedMessage = sanitizedMessage.replace(/['\"]?(\\/[\\w\\/\\.\\-\\_]+)['\"]?/g, '[path redacted]');\n+  // Remove Windows-style paths (e.g., C:\\Users\\app\\data)\n+  sanitizedMessage = sanitizedMessage.replace(/['\"]?([A-Z]:\\\\[\\w\\\\\\.\\-\\_]+)['\"]?/gi, '[path redacted]');\n+\n   return {\n     status: statusCode,\n-    // BUG: err.message often contains internal paths like\n-    // \"ENOENT: no such file or directory, open '/home/app/data/users.json'\"\n-    error: err.message,\n-    // BUG: exposes internal stack trace line\n-    path: err.stack ? err.stack.split('\\n')[1].trim() : null,\n+    error: sanitizedMessage,\n     code: err.code || null\n   };\n }"
      }
    ],
