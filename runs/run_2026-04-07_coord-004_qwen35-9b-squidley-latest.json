        "patch": "diff --git a/src/search/engine.js b/src/search/engine.js\nindex 463f139..adad096 100644\n--- a/src/search/engine.js\n+++ b/src/search/engine.js\n@@ -14,14 +14,20 @@ function search(query, documents) {\n   for (const doc of documents) {\n     let score = 0;\n     const content = doc.content || '';\n-\n+    \n+    const words = content.toLowerCase().split(/\\s+/);\n+    \n+    // Create a word frequency map for this document\n+    // This allows O(1) lookup per term instead of O(words) per term\n+    const wordMap = new Map();\n+    for (const word of words) {\n+      wordMap.set(word, (wordMap.get(word) || 0) + 1);\n+    }\n+    \n+    // For each term, look up in the map (O(1) per term)\n     for (const term of terms) {\n-      // BUG: re-splitting the document content for EVERY term creates O(terms * words) work\n-      // per document, making the total complexity O(docs * terms * words)\n-      const words = content.toLowerCase().split(/\\s+/);\n-      for (const word of words) {\n-        if (word === term) score++;\n-      }\n+      const count = wordMap.get(term) || 0;\n+      score += count;\n     }\n \n     if (score > 0) {"
