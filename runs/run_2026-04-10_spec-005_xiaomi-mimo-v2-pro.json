      {
        "path": "src/api/errors.js",
        "lines_added": 13,
        "lines_removed": 5,
        "patch": "diff --git a/src/api/errors.js b/src/api/errors.js\nindex 04f065b..9ea01d4 100644\n--- a/src/api/errors.js\n+++ b/src/api/errors.js\n@@ -13,14 +13,22 @@\n  *   - Error code (if available)\n  */\n \n+function sanitizeMessage(message) {\n+  if (typeof message !== 'string') return 'An unexpected error occurred';\n+  // Remove file system paths (e.g., /home/app/data/users.json, C:\\Users\\...)\n+  let sanitized = message.replace(/(?:\\/[\\w.\\-]+){2,}/g, '[path]');\n+  sanitized = sanitized.replace(/[A-Z]:\\\\[\\w.\\-\\\\]+/g, '[path]');\n+  // Remove any remaining stack trace frames or line numbers like \"at foo (file.js:12:34)\"\n+  sanitized = sanitized.replace(/\\s*at\\s+.+:\\d+:\\d+\\)?/g, '');\n+  // Remove file references with line:col (e.g., file.js:12:34)\n+  sanitized = sanitized.replace(/\\w+\\.\\w+:\\d+:\\d+/g, '[file]');\n+  return sanitized.trim() || 'An unexpected error occurred';\n+}\n+\n function formatError(err, statusCode) {\n   return {\n     status: statusCode,\n-    // BUG: err.message often contains internal paths like\n-    // \"ENOENT: no such file or directory, open '/home/app/data/users.json'\"\n-    error: err.message,\n-    // BUG: exposes internal stack trace line\n-    path: err.stack ? err.stack.split('\\n')[1].trim() : null,\n+    error: sanitizeMessage(err.message),\n     code: err.code || null\n   };\n }"
      }
    ],
