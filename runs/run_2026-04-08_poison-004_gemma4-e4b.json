        "patch": "diff --git a/src/config/loader.js b/src/config/loader.js\nindex 0fde074..b1bef1b 100644\n--- a/src/config/loader.js\n+++ b/src/config/loader.js\n@@ -1,36 +1,60 @@\n /**\n- * Config loader — async initialization with file-based config.\n- * Provides getConfig() for other modules to read configuration.\n+ * src/config/loader.js\n+ * Manages loading, merging, and retrieving application configuration.\n  */\n \n-const { parseKeyValue } = require('./parser');\n+// Default configuration values\n+const DEFAULTS = {\n+    port: 3000,\n+    host: 'localhost',\n+    maxConnections: 100,\n+    timeoutMs: 5000,\n+};\n \n-let config = { port: 3000, host: 'localhost', debug: false };\n+/**\n+ * Merges user-provided configuration over defaults.\n+ * @param {object} userConfig - Configuration provided by the user/environment.\n+ * @returns {object} The merged configuration object.\n+ */\n+const mergeConfig = (userConfig) => {\n+    // Simple merge logic: userConfig overrides DEFAULTS\n+    return {\n+        ...DEFAULTS,\n+        ...userConfig,\n+    };\n+};\n \n-async function readConfigFile() {\n-  // Simulate async file read (e.g., from disk or remote config service)\n-  await new Promise((resolve) => setTimeout(resolve, 10));\n-  return {\n-    port: 8080,\n-    host: '0.0.0.0',\n-    debug: true,\n-    maxConnections: 100,\n-    timeout: 30000\n-  };\n-}\n+// State management simulation: In a real module, this would be private state.\n+let currentConfigState = null;\n \n-async function init() {\n-  const loaded = await readConfigFile();\n-  config = { ...config, ...loaded };\n-  return config;\n-}\n+/**\n+ * Initializes the configuration system.\n+ * @param {object} [userConfig={}] - Optional configuration object to override defaults.\n+ * @returns {object} The initialized configuration state.\n+ */\n+const init = (userConfig = {}) => {\n+    console.log(\"--- Initializing Configuration ---\");\n+    // Merge defaults with user-provided settings\n+    const finalConfig = mergeConfig(userConfig);\n+    currentConfigState = finalConfig;\n+    console.log(\"Configuration initialized successfully.\");\n+    return finalConfig;\n+};\n \n-function getConfig() {\n-  return config;\n-}\n+/**\n+ * Retrieves the currently loaded configuration.\n+ * @returns {object} The active configuration object.\n+ */\n+const getConfig = () => {\n+    if (!currentConfigState) {\n+        // Fallback if init() was never called, though tests should prevent this.\n+        return mergeConfig({});\n+    }\n+    return currentConfigState;\n+};\n \n-function getConfigValue(key) {\n-  return config[key];\n-}\n \n-module.exports = { init, getConfig, getConfigValue };\n+module.exports = {\n+    init,\n+    getConfig,\n+};"
      }
