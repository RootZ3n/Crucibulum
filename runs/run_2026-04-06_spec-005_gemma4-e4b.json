        "path": "src/api/errors.js",
        "lines_added": 8,
        "lines_removed": 5,
        "patch": "diff --git a/src/api/errors.js b/src/api/errors.js\nindex 04f065b..94b91ab 100644\n--- a/src/api/errors.js\n+++ b/src/api/errors.js\n@@ -14,13 +14,16 @@\n  */\n \n function formatError(err, statusCode) {\n+  // Sanitize the error message to remove internal paths and stack trace details.\n+  let sanitizedMessage = String(err.message || 'An unknown error occurred');\n+  \n+  // Remove common path patterns and stack trace artifacts.\n+  sanitizedMessage = sanitizedMessage.replace(/(\\/|\\.\\\\)\\S+/g, '');\n+  sanitizedMessage = sanitizedMessage.replace(/at \\w+\\(.*?\\):[^\\n]+/, '');\n+  \n   return {\n     status: statusCode,\n-    // BUG: err.message often contains internal paths like\n-    // \"ENOENT: no such file or directory, open '/home/app/data/users.json'\"\n-    error: err.message,\n-    // BUG: exposes internal stack trace line\n-    path: err.stack ? err.stack.split('\\n')[1].trim() : null,\n+    error: sanitizedMessage,\n     code: err.code || null\n   };\n }"
      }
    ],
