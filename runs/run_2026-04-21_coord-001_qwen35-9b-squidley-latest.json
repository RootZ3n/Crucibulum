      {
        "path": "src/users/register.js",
        "lines_added": 9,
        "lines_removed": 2,
        "patch": "diff --git a/src/users/register.js b/src/users/register.js\nindex 71846f8..9135a72 100644\n--- a/src/users/register.js\n+++ b/src/users/register.js\n@@ -1,15 +1,22 @@\n const { validate } = require('./validate');\n-const { saveUser } = require('./store');\n+const { saveUser, findByEmail } = require('./store');\n \n /**\n  * Registers a new user.\n  * Validates the email, then saves the user to the store.\n  */\n async function register(email, name) {\n-  const validation = validate(email);\n+  const validation = await validate(email);\n   if (validation.error) {\n     return { success: false, error: validation.error };\n   }\n+  \n+  // Check if user with this email already exists\n+  const existingUser = await findByEmail(email);\n+  if (existingUser) {\n+    return { success: false, error: 'Email already registered' };\n+  }\n+  \n   const user = await saveUser({ email, name });\n   return { success: true, user };\n }"
      }
