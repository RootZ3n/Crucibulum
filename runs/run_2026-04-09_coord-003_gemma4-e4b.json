      {
        "path": "src/cache/middleware.js",
        "lines_added": 25,
        "lines_removed": 5,
        "patch": "diff --git a/src/cache/middleware.js b/src/cache/middleware.js\nindex 2baedc3..0877b81 100644\n--- a/src/cache/middleware.js\n+++ b/src/cache/middleware.js\n@@ -11,13 +11,33 @@ const { fetchAndCache } = require('./fetcher');\n async function cacheMiddleware({ key, fetchFn, ttlMs }) {\n   // Try serving from cache\n   const cached = store.get(key);\n-  if (cached !== null) {\n-    return cached;\n+\n+  // Check if cache exists and is not expired\n+  if (cached && cached.expiry && cached.expiry > Date.now()) {\n+    console.log(`Cache HIT for key: ${key}`);\n+    return cached.data;\n   }\n \n-  // Fetch, cache, and return\n-  const data = await fetchAndCache(key, fetchFn, ttlMs);\n-  return data;\n+  // Cache miss or expired: Fetch, cache, and return\n+  console.log(`Cache MISS or EXPIRED for key: ${key}. Fetching fresh data.`);\n+  \n+  try {\n+    // Use the existing fetchAndCache, but we must ensure it returns data \n+    // that we can then wrap with expiry info.\n+    // Assuming fetchAndCache returns the raw data object.\n+    const data = await fetchAndCache(key, fetchFn, ttlMs);\n+\n+    // Calculate expiry time\n+    const expiryTime = Date.now() + ttlMs;\n+\n+    // Store the data along with the calculated expiry time\n+    store.set(key, { data: data, expiry: expiryTime });\n+    \n+    return data;\n+  } catch (error) {\n+    console.error(`Error during cache middleware execution for key ${key}:`, error);\n+    throw error;\n+  }\n }\n \n /**"
      }
