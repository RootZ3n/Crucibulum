        "patch": "diff --git a/src/queue/processor.js b/src/queue/processor.js\nindex 409440b..67518c1 100644\n--- a/src/queue/processor.js\n+++ b/src/queue/processor.js\n@@ -16,9 +16,8 @@ async function doWork(item) {\n }\n \n async function processNext(item) {\n-  const seq = sequence;   // read current value\n-  await doWork(item);     // async work happens between read and write\n-  sequence = seq + 1;     // write back after async gap — race window\n+  const seq = sequence++;  // atomically reserve a unique sequence number\n+  await doWork(item);      // async work — no race on sequence anymore\n   return { id: item.id, sequence: seq, status: 'done' };\n }"
