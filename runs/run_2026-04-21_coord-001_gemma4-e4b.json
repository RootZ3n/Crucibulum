      {
        "path": "src/users/register.js",
        "lines_added": 10,
        "lines_removed": 2,
        "patch": "diff --git a/src/users/register.js b/src/users/register.js\nindex 71846f8..18898a9 100644\n--- a/src/users/register.js\n+++ b/src/users/register.js\n@@ -1,15 +1,23 @@\n const { validate } = require('./validate');\n-const { saveUser } = require('./store');\n+const { saveUser, findByEmail } = require('./store');\n \n /**\n  * Registers a new user.\n- * Validates the email, then saves the user to the store.\n+ * Validates the email, checks for duplicates, then saves the user to the store.\n  */\n async function register(email, name) {\n   const validation = validate(email);\n   if (validation.error) {\n     return { success: false, error: validation.error };\n   }\n+\n+  // Check if user already exists\n+  const existingUser = await findByEmail(email);\n+  if (existingUser) {\n+    return { success: false, error: 'Email already registered' };\n+  }\n+\n+  // If no duplicate, save the user\n   const user = await saveUser({ email, name });\n   return { success: true, user };\n }"
      },
      {
        "path": "tests/register.test.js",
        "lines_added": 9,
        "lines_removed": 0,
        "patch": "diff --git a/tests/register.test.js b/tests/register.test.js\nindex d8612c9..e9cfbce 100644\n--- a/tests/register.test.js\n+++ b/tests/register.test.js\n@@ -37,6 +37,15 @@ async function run() {\n   const users2 = getAllUsers();\n   assert(users2.length === 2, 'Two users stored');\n \n+  // Test 4: Attempt to register a duplicate email\n+  const result3 = await register('alice@example.com', 'Another Alice');\n+  assert(result3.success === false, 'Duplicate registration fails');\n+  assert(result3.error === 'Email already registered', 'Error message for duplicate email is correct');\n+\n+  const users3 = getAllUsers();\n+  assert(users3.length === 2, 'Total number of users remains unchanged after duplicate attempt');\n+\n+\n   console.log(`\\nResults: ${passed} passed, ${failed} failed`);\n   if (failed > 0) process.exit(1);\n }"
      }
    ],
