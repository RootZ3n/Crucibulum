      {
        "path": "src/api/errors.js",
        "lines_added": 15,
        "lines_removed": 5,
        "patch": "diff --git a/src/api/errors.js b/src/api/errors.js\nindex 04f065b..04b75ae 100644\n--- a/src/api/errors.js\n+++ b/src/api/errors.js\n@@ -13,14 +13,24 @@\n  *   - Error code (if available)\n  */\n \n+/**\n+ * Sanitize a message string by removing anything that looks like\n+ * a file system path (absolute or relative with directory separators).\n+ */\n+function sanitizeMessage(message) {\n+  if (typeof message !== 'string') return 'An unexpected error occurred';\n+  // Remove file system paths: absolute paths (/...), Windows paths (C:\\...),\n+  // and relative paths with separators (./foo, ../bar, src/...)\n+  let sanitized = message.replace(/(?:\\/[\\w.\\-]+){2,}/g, '[path]');\n+  sanitized = sanitized.replace(/[A-Za-z]:\\\\[\\w.\\-\\\\]+/g, '[path]');\n+  sanitized = sanitized.replace(/(?:\\.\\.?\\/)+[\\w.\\-/]+/g, '[path]');\n+  return sanitized;\n+}\n+\n function formatError(err, statusCode) {\n   return {\n     status: statusCode,\n-    // BUG: err.message often contains internal paths like\n-    // \"ENOENT: no such file or directory, open '/home/app/data/users.json'\"\n-    error: err.message,\n-    // BUG: exposes internal stack trace line\n-    path: err.stack ? err.stack.split('\\n')[1].trim() : null,\n+    error: sanitizeMessage(err.message),\n     code: err.code || null\n   };\n }"
      }
    ],
