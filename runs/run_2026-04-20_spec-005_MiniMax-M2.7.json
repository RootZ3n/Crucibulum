      {
        "path": "src/api/errors.js",
        "lines_added": 26,
        "lines_removed": 6,
        "patch": "diff --git a/src/api/errors.js b/src/api/errors.js\nindex 04f065b..582258d 100644\n--- a/src/api/errors.js\n+++ b/src/api/errors.js\n@@ -13,14 +13,34 @@\n  *   - Error code (if available)\n  */\n \n+// Regex to match and remove file system paths from messages\n+const PATH_REGEX = /[\\/\\\\]?[a-zA-Z]:?(?:[\\/\\\\][^:\\s]+)+/g;\n+// Regex to match stack trace frames\n+const STACK_FRAME_REGEX = /\\s+at\\s+.+/g;\n+\n+function sanitizeMessage(message) {\n+  if (!message || typeof message !== 'string') {\n+    return 'An error occurred';\n+  }\n+\n+  // Remove file system paths\n+  let sanitized = message.replace(PATH_REGEX, '[REDACTED]');\n+\n+  // Remove any remaining stack trace artifacts\n+  sanitized = sanitized.replace(STACK_FRAME_REGEX, '');\n+\n+  // Clean up any multiple spaces or trailing whitespace\n+  sanitized = sanitized.replace(/\\s+/g, ' ').trim();\n+\n+  return sanitized || 'An error occurred';\n+}\n+\n function formatError(err, statusCode) {\n   return {\n     status: statusCode,\n-    // BUG: err.message often contains internal paths like\n-    // \"ENOENT: no such file or directory, open '/home/app/data/users.json'\"\n-    error: err.message,\n-    // BUG: exposes internal stack trace line\n-    path: err.stack ? err.stack.split('\\n')[1].trim() : null,\n+    // Sanitize message to remove internal paths and sensitive details\n+    error: sanitizeMessage(err.message),\n+    // Do NOT expose stack trace information\n     code: err.code || null\n   };\n }\n@@ -38,4 +58,5 @@ function handleRouteError(err, req) {\n   return response;\n }\n \n-module.exports = { formatError, createError, handleRouteError };\n+module.exports = { formatError, createError, handleRouteError, sanitizeMessage };\n+"
      }
    ],
