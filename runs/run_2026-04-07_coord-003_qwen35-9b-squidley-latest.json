  "diff": {
    "files_changed": [
      {
        "path": "src/cache/fetcher.js",
        "lines_added": 6,
        "lines_removed": 6,
        "patch": "diff --git a/src/cache/fetcher.js b/src/cache/fetcher.js\nindex 52e342b..efdd15f 100644\n--- a/src/cache/fetcher.js\n+++ b/src/cache/fetcher.js\n@@ -1,10 +1,10 @@\n-const store = require('./store');\n-\n /**\n  * Fetches data from a source and caches the result.\n  * fetchFn should return a Response-like object with a .json() method,\n  * simulating a network fetch.\n  */\n+const store = require('./store');\n+\n const DEFAULT_TTL = 60000; // 60 seconds\n \n async function fetchAndCache(key, fetchFn, ttlMs = DEFAULT_TTL) {\n@@ -16,11 +16,11 @@ async function fetchAndCache(key, fetchFn, ttlMs = DEFAULT_TTL) {\n   // Cache miss — fetch from source\n   const response = await fetchFn();\n \n-  // Store the result in cache\n-  store.set(key, response, ttlMs);\n-\n-  // Return parsed data for the caller\n+  // Store the parsed result in cache, not the raw response\n   const data = await response.json();\n+  store.set(key, data, ttlMs);\n+\n+  // Return parsed data\n   return data;\n }"
      },
      {
        "path": "src/cache/store.js",
        "lines_added": 3,
        "lines_removed": 3,
        "patch": "diff --git a/src/cache/store.js b/src/cache/store.js\nindex 52280fa..8820869 100644\n--- a/src/cache/store.js\n+++ b/src/cache/store.js\n@@ -15,8 +15,8 @@ function get(key) {\n   const entry = cache.get(key);\n   if (!entry) return null;\n \n-  // Check if expired\n-  if (Date.now() > entry.expiresAt) {\n+  // Check if expired - use >= to expire at TTL boundary\n+  if (Date.now() >= entry.expiresAt) {\n     cache.delete(key);\n     return null;\n   }\n@@ -28,7 +28,7 @@ function has(key) {\n   const entry = cache.get(key);\n   if (!entry) return false;\n \n-  if (Date.now() > entry.expiresAt) {\n+  if (Date.now() >= entry.expiresAt) {\n     cache.delete(key);\n     return false;\n   }"
      }
    ],
