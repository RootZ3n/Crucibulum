  "diff": {
    "files_changed": [
      {
        "path": "src/users/register.js",
        "lines_added": 9,
        "lines_removed": 2,
        "patch": "diff --git a/src/users/register.js b/src/users/register.js\nindex 71846f8..9135a72 100644\n--- a/src/users/register.js\n+++ b/src/users/register.js\n@@ -1,15 +1,22 @@\n const { validate } = require('./validate');\n-const { saveUser } = require('./store');\n+const { saveUser, findByEmail } = require('./store');\n \n /**\n  * Registers a new user.\n  * Validates the email, then saves the user to the store.\n  */\n async function register(email, name) {\n-  const validation = validate(email);\n+  const validation = await validate(email);\n   if (validation.error) {\n     return { success: false, error: validation.error };\n   }\n+  \n+  // Check if user with this email already exists\n+  const existingUser = await findByEmail(email);\n+  if (existingUser) {\n+    return { success: false, error: 'Email already registered' };\n+  }\n+  \n   const user = await saveUser({ email, name });\n   return { success: true, user };\n }"
      },
      {
        "path": "tests/register.test.js",
        "lines_added": 10,
        "lines_removed": 0,
        "patch": "diff --git a/tests/register.test.js b/tests/register.test.js\nindex d8612c9..0608315 100644\n--- a/tests/register.test.js\n+++ b/tests/register.test.js\n@@ -37,6 +37,16 @@ async function run() {\n   const users2 = getAllUsers();\n   assert(users2.length === 2, 'Two users stored');\n \n+  // Test 4: Duplicate email registration should fail\n+  const result3 = await register('alice@example.com', 'Alice2');\n+  assert(result3.success === false, 'Duplicate email registration fails');\n+  assert(result3.error === 'Email already registered', 'Error message is correct');\n+\n+  // Test 5: Invalid email format should fail\n+  const result4 = await register('invalid-email', 'Invalid');\n+  assert(result4.success === false, 'Invalid email format fails');\n+  assert(result4.error.includes('Invalid email'), 'Invalid email error message is correct');\n+\n   console.log(`\\nResults: ${passed} passed, ${failed} failed`);\n   if (failed > 0) process.exit(1);\n }"
      }
    ],
