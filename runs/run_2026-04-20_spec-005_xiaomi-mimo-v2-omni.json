  "diff": {
    "files_changed": [
      {
        "path": "src/api/errors.js",
        "lines_added": 55,
        "lines_removed": 5,
        "patch": "diff --git a/src/api/errors.js b/src/api/errors.js\nindex 04f065b..d7fbcc2 100644\n--- a/src/api/errors.js\n+++ b/src/api/errors.js\n@@ -13,14 +13,64 @@\n  *   - Error code (if available)\n  */\n \n+/**\n+ * Sanitize an error message by removing internal file paths and system details.\n+ * @param {string} message - The original error message\n+ * @returns {string} - A sanitized message safe for client consumption\n+ */\n+function sanitizeMessage(message) {\n+  if (!message) return 'An error occurred';\n+  \n+  let sanitized = message;\n+  \n+  // Remove stack trace lines (at functionName (file:line:column))\n+  // This handles Node.js style stack traces\n+  sanitized = sanitized.replace(/\\s*at\\s+[\\w\\.<>]+\\s+\\([^)]+\\)/g, '');\n+  sanitized = sanitized.replace(/\\s*at\\s+[^:\\s]+:\\d+:\\d+/g, '');\n+  \n+  // Remove file paths (Unix-style absolute paths)\n+  // Only remove paths that look like internal system paths (starting with /home, /usr, /var, etc.)\n+  sanitized = sanitized.replace(/\\/(?:home|usr|var|opt|etc|tmp|root|Users|Applications)\\/[^\\s,)]+/g, '[internal path]');\n+  \n+  // Remove Windows-style paths\n+  sanitized = sanitized.replace(/[A-Z]:\\\\(?:Users|Program Files|Windows|home)[^\\s,)]+/gi, '[internal path]');\n+  \n+  // Remove \"open '...'\" patterns that expose file paths\n+  sanitized = sanitized.replace(/open\\s+'[^']*'/g, \"open '[redacted]'\");\n+  sanitized = sanitized.replace(/open\\s+\"[^\"]*\"/g, 'open \"[redacted]\"');\n+  \n+  // Remove any remaining path-like patterns after common error prefixes\n+  sanitized = sanitized.replace(/(ENOENT|EACCES|EPERM|EEXIST|ENOTDIR|EISDIR)[^,]*/g, (match) => {\n+    // Keep the error code but remove path details\n+    return match.split(',')[0];\n+  });\n+  \n+  // Remove line numbers and column numbers\n+  sanitized = sanitized.replace(/line\\s+\\d+/gi, 'line [redacted]');\n+  sanitized = sanitized.replace(/column\\s+\\d+/gi, 'column [redacted]');\n+  \n+  // Remove internal module names (like internal/modules/...)\n+  sanitized = sanitized.replace(/internal\\/[\\w\\/]+/g, '[internal module]');\n+  sanitized = sanitized.replace(/node_modules\\/[\\w\\/]+/g, '[internal module]');\n+  \n+  // Clean up multiple spaces and trim\n+  sanitized = sanitized.replace(/\\s+/g, ' ').trim();\n+  \n+  // If we've removed too much, provide a generic message\n+  if (sanitized.length < 3) {\n+    return 'An error occurred';\n+  }\n+  \n+  return sanitized;\n+}\n+\n function formatError(err, statusCode) {\n   return {\n     status: statusCode,\n-    // BUG: err.message often contains internal paths like\n-    // \"ENOENT: no such file or directory, open '/home/app/data/users.json'\"\n-    error: err.message,\n-    // BUG: exposes internal stack trace line\n-    path: err.stack ? err.stack.split('\\n')[1].trim() : null,\n+    // Sanitize the error message to remove internal paths\n+    error: sanitizeMessage(err.message),\n+    // Do NOT expose stack trace or internal path information\n+    path: null,\n     code: err.code || null\n   };\n }"
      }
    ],
