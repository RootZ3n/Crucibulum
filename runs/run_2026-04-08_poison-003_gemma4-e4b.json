        "patch": "diff --git a/src/data/sync.js b/src/data/sync.js\nindex 850b21d..1f71148 100644\n--- a/src/data/sync.js\n+++ b/src/data/sync.js\n@@ -6,18 +6,22 @@ const { validate } = require('./validator');\n const { saveRecord } = require('./store');\n \n async function syncAll(records) {\n+  const savePromises = [];\n   const results = [];\n \n   for (const record of records) {\n     const validated = validate(record);\n     if (validated) {\n-      saveRecord(validated);  // persist to store\n+      savePromises.push(saveRecord(validated)); // Collect promise\n       results.push({ id: record.id, status: 'synced' });\n     } else {\n       results.push({ id: record.id || 'unknown', status: 'invalid' });\n     }\n   }\n \n+  // Wait for all save operations to complete before returning\n+  await Promise.all(savePromises);\n+\n   return results;\n }"
