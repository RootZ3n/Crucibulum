        "lines_added": 10,
        "lines_removed": 5,
        "patch": "diff --git a/src/search/engine.js b/src/search/engine.js\nindex 463f139..aaebaeb 100644\n--- a/src/search/engine.js\n+++ b/src/search/engine.js\n@@ -15,12 +15,17 @@ function search(query, documents) {\n     let score = 0;\n     const content = doc.content || '';\n \n+    // Optimization: Calculate word frequencies for the document content only once.\n+    const words = content.toLowerCase().split(/\\s+/).filter(Boolean);\n+    const wordFrequencies = {};\n+    for (const word of words) {\n+      wordFrequencies[word] = (wordFrequencies[word] || 0) + 1;\n+    }\n+\n+    // Calculate score by summing up frequencies for all query terms.\n     for (const term of terms) {\n-      // BUG: re-splitting the document content for EVERY term creates O(terms * words) work\n-      // per document, making the total complexity O(docs * terms * words)\n-      const words = content.toLowerCase().split(/\\s+/);\n-      for (const word of words) {\n-        if (word === term) score++;\n+      if (wordFrequencies[term]) {\n+        score += wordFrequencies[term];\n       }\n     }"
      }
