        "lines_added": 4,
        "lines_removed": 5,
        "patch": "diff --git a/src/parser/validator.js b/src/parser/validator.js\nindex 5c40202..80603bb 100644\n--- a/src/parser/validator.js\n+++ b/src/parser/validator.js\n@@ -2,11 +2,10 @@\n  * Input validator — validates user-provided fields.\n  */\n \n-// BUG: This regex has catastrophic backtracking on adversarial inputs.\n-// The pattern ([a-zA-Z0-9.]+)* creates nested quantifiers where the dot\n-// is matched by both the character class and the outer repetition,\n-// causing exponential backtracking when input ends with an invalid character.\n-const EMAIL_REGEX = /^([a-zA-Z0-9.]+)*@[a-zA-Z0-9]+(\\.[a-zA-Z]{2,})+$/;\n+// Fixed: removed the outer * quantifier that caused catastrophic backtracking.\n+// The inner + already handles one or more characters; wrapping it in * created\n+// nested quantifiers leading to exponential backtracking on invalid inputs.\n+const EMAIL_REGEX = /^[a-zA-Z0-9.]+@[a-zA-Z0-9]+(\\.[a-zA-Z]{2,})+$/;\n \n function validateEmail(email) {\n   if (typeof email !== 'string') return false;"
      }
