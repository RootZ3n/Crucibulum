        "path": "src/users/validate.js",
        "lines_added": 0,
        "lines_removed": 26,
        "patch": "diff --git a/src/users/validate.js b/src/users/validate.js\nindex ea42692..e69de29 100644\n--- a/src/users/validate.js\n+++ b/src/users/validate.js\n@@ -1,26 +0,0 @@\n-const { findByEmail } = require('./store');\n-\n-const EMAIL_REGEX = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n-\n-/**\n- * Validates a user email for format and uniqueness.\n- * Returns { valid: true } or { valid: false, error: \"...\" }\n- */\n-async function validate(email) {\n-  if (!email || typeof email !== 'string') {\n-    return { valid: false, error: 'Email is required' };\n-  }\n-\n-  if (!EMAIL_REGEX.test(email)) {\n-    return { valid: false, error: 'Invalid email format' };\n-  }\n-\n-  const existing = await findByEmail(email);\n-  if (existing) {\n-    return { valid: false, error: 'Email already registered' };\n-  }\n-\n-  return { valid: true };\n-}\n-\n-module.exports = { validate };"
      }
    ],
