      {
        "path": "src/api/errors.js",
        "lines_added": 20,
        "lines_removed": 5,
        "patch": "diff --git a/src/api/errors.js b/src/api/errors.js\nindex 04f065b..5a694ee 100644\n--- a/src/api/errors.js\n+++ b/src/api/errors.js\n@@ -13,14 +13,29 @@\n  *   - Error code (if available)\n  */\n \n+function sanitizeErrorMessage(message) {\n+  // Remove internal file system paths from error messages\n+  let sanitized = message;\n+  \n+  // Remove absolute paths like /home/user/app/src/...\n+  sanitized = sanitized.replace(/\\/[^/]+\\/[^/]+\\/[^/]+\\/[^/]+/g, '');\n+  \n+  // Remove relative paths that look like internal paths\n+  sanitized = sanitized.replace(/(ENOENT|EACCES|EISDIR):.*open.*['\"][^'\"]+['\"]/g, '$1: no such file or directory');\n+  \n+  // Remove stack trace references\n+  sanitized = sanitized.replace(/at [^:]+:\\d+:/g, 'at <sanitized>');\n+  \n+  return sanitized;\n+}\n+\n function formatError(err, statusCode) {\n   return {\n     status: statusCode,\n-    // BUG: err.message often contains internal paths like\n-    // \"ENOENT: no such file or directory, open '/home/app/data/users.json'\"\n-    error: err.message,\n-    // BUG: exposes internal stack trace line\n-    path: err.stack ? err.stack.split('\\n')[1].trim() : null,\n+    // Sanitized error message without internal paths\n+    error: sanitizeErrorMessage(err.message),\n+    // Removed: stack trace exposed internal paths and line numbers\n+    path: null,\n     code: err.code || null\n   };\n }"
      }
    ],
