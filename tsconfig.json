{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["cli/**/*.ts", "core/**/*.ts", "adapters/**/*.ts", "utils/**/*.ts", "schemas/**/*.ts", "security/**/*.ts", "leaderboard/**/*.ts", "server/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "tasks", "oracles", "runs", "tests/flake-detection.test.ts", "tests/suite-scoring.test.ts", "tests/cleanup.test.ts", "tests/suite-flake.test.ts", "tests/leaderboard-ranking.test.ts", "tests/reporting-fields.test.ts"]
}
