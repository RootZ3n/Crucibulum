# Crucible Configuration
#
# Copy this file to .env for local development. Do not commit real secrets.
#
# Provider API Keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
ZAI_API_KEY=
MINIMAX_API_KEY=
MODELSTUDIO_API_KEY=
#
# Local / Subprocess Providers
OLLAMA_URL=http://localhost:11434
OPENCLAW_BINARY=/usr/local/bin/openclaw
OPENCLAW_MODEL=
OPENCLAW_PROVIDER=
OPENCLAW_CONFIG=
CLAUDE_CODE_BINARY=claude
CLAUDE_CODE_MODEL=
SQUIDLEY_URL=http://localhost:18791
#
# Server / State
CRUCIBLE_HOST=127.0.0.1
CRUCIBLE_PORT=18795
CRUCIBLE_STATE_ROOT=./state
CRUCIBLE_HMAC_KEY=
CRUCIBLE_API_TOKEN=
CRUCIBLE_ALLOW_LOCAL=true
#
# Compatibility names still consumed by older Crucibulum-era code paths.
# Prefer the CRUCIBLE_* names above for new deployments.
# CRUCIBULUM_HOST=127.0.0.1
# CRUCIBULUM_PORT=18795
# CRUCIBULUM_STATE_DIR=./state
# CRUCIBULUM_API_TOKEN=
# CRUCIBULUM_ALLOW_LOCAL=true
#
# Harness / Evidence Locations
CRUCIBULUM_RUNS_DIR=./runs
CRUCIBULUM_TASKS_DIR=./tasks
CRUCIBULUM_SUITES_DIR=./suites
CRUCIBULUM_LINKS_DIR=./runs
CRUCIBULUM_MEMORY_DIR=./state/memory-sessions
CRUCIBULUM_LOG_LEVEL=info
#
# Judge model (advisory model judge layered on the deterministic scorer).
# Defaults to OpenRouter "xiaomi/mimo-v2-pro" — the closest registered
# OpenRouter id for the Xiaomi MiMo V2.5 Pro line. Override either field
# to swap providers/models. Fallback: when the judge provider is
# unreachable, only the deterministic scorer runs and the model judge is
# recorded as "skipped".
CRUCIBLE_JUDGE_PROVIDER=openrouter
CRUCIBLE_JUDGE_MODEL=xiaomi/mimo-v2-pro
